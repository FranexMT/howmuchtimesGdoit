generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model BathroomLog {
  id              Int      @id @default(autoincrement())
  timestamp       DateTime @default(now())
  durationSeconds Int
  userAgent       String?
}

model FoodLog {
  id             Int      @id @default(autoincrement())
  timestamp      DateTime @default(now())
  foodType       String
  estimatedPrice Float
  userAgent      String?
}

model SalidaLog {
  id              Int      @id @default(autoincrement())
  timestamp       DateTime @default(now())
  durationSeconds Int
  userAgent       String?
}
